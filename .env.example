# Smart Backlog Assistant - environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# -------------------------------------------------------------------
# Provider selection
# -------------------------------------------------------------------

# "openai" (default) or "anthropic"
AI_PROVIDER=openai

# Optional: override the default chat model for the chosen provider.
# OpenAI default    : gpt-4o-mini (best combination of cost and effectiveness)
# Anthropic default : claude-sonnet-4-6 (best combination of cost and effectiveness)

# -------------------------------------------------------------------
# API keys
# -------------------------------------------------------------------

# OpenAI API key. Use a standard key (sk-...) or a Vocareum key (voc-...).
# Required when AI_PROVIDER=openai (or for embeddings in all cases)
OPENAI_API_KEY="voc-00000000000000000000000000000000abcd.12345678"
OPENAI_BASE_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"
OPENAI_BASE_URL="https://openai.vocareum.com/v1"

# Anthropic API key (only required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="voc-00000000000000000000000000000000abcd.12345678"
ANTHROPIC_BASE_MODEL="claude-sonnet-4-6"
ANTHROPIC_BASE_URL="https://claude.vocareum.com"

# -------------------------------------------------------------------
# Notes
# -------------------------------------------------------------------
# When using AI_PROVIDER=anthropic, OPENAI_API_KEY is still required
# because Anthropic does not provide an embedding API.  Embeddings
# (used by the RoutingAgent for semantic step routing) always call
# OpenAI's text-embedding-3-large model.
